# =============================================================
# CarLink WEB (Next.js) — Variables d'environnement
# =============================================================
# INSTRUCTIONS :
#   1. Copie ce fichier : cp apps/web/.env.example apps/web/.env.local
#   2. Remplis les valeurs avec tes vraies clés
#   3. Ne committe JAMAIS .env.local (déjà dans .gitignore)
#
# Où trouver les clés : https://app.supabase.com → Settings → API
# =============================================================

# ----- SUPABASE CLIENT (exposé au browser) -----
# Préfixe NEXT_PUBLIC_ = accessible dans le code client React
# Protégé par RLS côté Supabase — safe à exposer

# Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxx.supabase.co

# Clé anon/public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ----- SUPABASE SERVER (jamais exposé au browser) -----
# Sans préfixe NEXT_PUBLIC_ = accessible uniquement côté serveur Next.js
# Utilisé dans : Server Components, Route Handlers, Server Actions
# Voir : apps/web/lib/supabase-server.ts

# ⚠️  Clé service_role — bypasse toutes les policies RLS
SUPABASE_SERVICE_ROLE_KEY=

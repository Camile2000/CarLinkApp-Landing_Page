# =============================================================
# CarLink MOBILE (Expo / React Native) — Variables d'environnement
# =============================================================
# INSTRUCTIONS :
#   1. Copie ce fichier : cp apps/mobile/.env.example apps/mobile/.env
#   2. Remplis les valeurs avec tes vraies clés
#   3. Ne committe JAMAIS .env (déjà dans .gitignore)
#   4. Après modification, relance Expo : npx expo start --clear
#
# Où trouver les clés : https://app.supabase.com → Settings → API
# =============================================================

# ----- SUPABASE -----
# Préfixe EXPO_PUBLIC_ = embarqué dans le bundle de l'app (visible)
# Protégé par RLS côté Supabase — safe à embarquer dans l'app

# Project URL
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxx.supabase.co

# Clé anon/public
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ----- GOOGLE MAPS (Semaine 3) -----
# Laisser vide jusqu'à la S3
# → https://console.cloud.google.com → Maps SDK for Android/iOS
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

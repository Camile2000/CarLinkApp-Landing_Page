# =============================================================
# CarLink — Variables d'environnement GLOBALES
# =============================================================
# INSTRUCTIONS :
#   1. Copie ce fichier : cp .env.example .env
#   2. Remplis les valeurs avec tes vraies clés
#   3. Ne committe JAMAIS le fichier .env (déjà dans .gitignore)
#
# Où trouver les clés Supabase :
#   → https://app.supabase.com → ton projet → Settings → API
# =============================================================

# ----- SUPABASE -----
# Project URL (visible dans Settings → API → Project URL)
SUPABASE_URL=https://hmpwmvoovkgcgzdpctqt.supabase.co

# Clé publique anon (visible dans Settings → API → Project API Keys → anon/public)
# Peut être exposée côté client — RLS la protège
SUPABASE_ANON_KEY=

# Clé service_role (visible dans Settings → API → Project API Keys → service_role)
# ⚠️  NE JAMAIS EXPOSER côté client — bypasse RLS complètement
SUPABASE_SERVICE_ROLE_KEY=

# ----- GOOGLE MAPS (Semaine 3) -----
# Laisser vide jusqu'à la S3
# → https://console.cloud.google.com → Maps JavaScript API
GOOGLE_MAPS_API_KEY=

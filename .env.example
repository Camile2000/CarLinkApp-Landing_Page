# Modèle global — copie en .env et remplis avec tes vraies clés Supabase
# (Settings → API dans le dashboard Supabase)
#
# Voir aussi : apps/mobile/.env.example  et  apps/web/.env.example

SUPABASE_URL=https://xxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
GOOGLE_MAPS_API_KEY=
